---
// Central SEO head. Renders meta, Open Graph, Twitter cards, canonical, and
// JSON-LD structured data for every page. Article pages pass type="article".
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;            // raster OG image path; falls back to brand default
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  tags?: string[];
  section?: string;          // article section (primary category)
  canonicalURL?: string;     // override (e.g. cross-domain canonical)
  noindex?: boolean;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = 'Justin Smith',
  tags = [],
  section,
  canonicalURL,
  noindex = false,
} = Astro.props;

const SITE_NAME = 'The Ink & Steel';
const site = Astro.site ?? new URL('https://www.inksteeljournal.com');
const canonical = canonicalURL ?? new URL(Astro.url.pathname, site).href;
// Social platforms need a raster image; SVG heroes fall back to the brand card.
const isRaster = image && /\.(png|jpe?g|webp)$/i.test(image);
const ogImage = new URL(isRaster ? image! : '/og/og-default.png', site).href;

// --- Structured data (schema.org) ---------------------------------------
const orgLogo = new URL('/og/og-default.png', site).href;
const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        image: ogImage,
        datePublished: publishedTime?.toISOString(),
        dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
        author: { '@type': 'Person', name: author },
        publisher: {
          '@type': 'Organization',
          name: SITE_NAME,
          logo: { '@type': 'ImageObject', url: orgLogo },
        },
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
        keywords: tags.join(', '),
        articleSection: section,
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE_NAME,
        url: site.href,
        description,
        publisher: {
          '@type': 'Organization',
          name: SITE_NAME,
          logo: { '@type': 'ImageObject', url: orgLogo },
        },
      };
---

<!-- Essentials -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-image-preview:large" />}
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
<meta name="author" content={author} />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#f7f3ea" />

<!-- Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="mask-icon" href="/favicon.svg" color="#8c2b27" />

<!-- Feeds -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE_NAME} — Blog`}
  href={new URL('/rss.xml', site).href}
/>
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Open Graph -->
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />
{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{type === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime.toISOString()} />
)}
{type === 'article' && <meta property="article:author" content={author} />}
{type === 'article' && section && <meta property="article:section" content={section} />}
{type === 'article' && tags.map((t) => <meta property="article:tag" content={t} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
