---
import Logo from './Logo.astro';
import Newsletter from './Newsletter.astro';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer__grid">
    <div class="footer__brand">
      <Logo variant="stacked" />
      <p class="footer__motto">
        The pen is mightier than the sword. <em>Ink &amp; Steel.</em>
      </p>
    </div>

    <div class="footer__signup">
      <Newsletter compact />
    </div>

    <nav class="footer__links" aria-label="Footer">
      <p class="footer__heading">Sections</p>
      <a href="/blog">The Blog</a>
      <a href="/the-record">The Record</a>
      <a href="/about-me">About</a>
      <a href="/faqs">FAQ</a>
      <a href="/rss.xml">RSS Feed</a>
    </nav>
  </div>

  <div class="wrap footer__base">
    <p>© {year} The Ink &amp; Steel · Justin Smith. All rights reserved.</p>
    <p class="footer__note">Independent political commentary. Opinions are the author's own.</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 5rem;
    border-top: 2px solid var(--ink);
    background: var(--paper-deep);
    background-image: var(--paper-grain);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.2fr 1.4fr 0.8fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    padding-block: 3rem 2rem;
  }
  .footer__motto {
    margin-top: 1rem;
    font-family: var(--font-display);
    color: var(--ink-soft);
    font-size: var(--step-0);
    max-width: 22rem;
  }
  .footer__heading {
    font-family: var(--font-display);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--oxblood);
    margin-bottom: 0.7rem;
  }
  .footer__links { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer__links a { color: var(--ink); text-decoration: none; width: fit-content; }
  .footer__links a:hover { color: var(--oxblood); text-decoration: underline; text-underline-offset: 0.18em; }
  .footer__base {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-block: 1.3rem;
    border-top: 1px solid var(--paper-edge);
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
  @media (max-width: 720px) {
    .footer__grid { grid-template-columns: 1fr; }
  }
</style>
