---
import { withBase } from '../lib/utils';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer__grid">
    <div class="footer__brand">
      <p class="footer__word">The Ink <span class="footer__amp">&amp;</span> Steel</p>
      <p class="footer__motto">The pen is mightier than the sword. Uncommon sense for the common man.</p>
    </div>

    <nav class="footer__links" aria-label="Footer">
      <p class="footer__heading">Sections</p>
      <a href={withBase('/blog')}>The Blog</a>
      <a href={withBase('/the-record')}>The Record</a>
      <a href={withBase('/about-me')}>About</a>
      <a href={withBase('/faqs')}>FAQ</a>
      <a href={withBase('/rss.xml')}>RSS Feed</a>
    </nav>
  </div>

  <div class="wrap footer__base">
    <p>© {year} The Ink &amp; Steel · Justin Smith. All rights reserved.</p>
    <p class="footer__note">Independent political commentary. Opinions are the author's own.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--navy-deep);
    background-image: var(--leather-grain);
    border-top: 3px solid var(--gold-deep);
    color: var(--paper-deep);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 0.8fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    padding-block: clamp(2.2rem, 5vw, 3.2rem) 1.6rem;
  }
  .footer__word {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: var(--step-2);
    background: linear-gradient(180deg, #f6e6b4, #c79a45 60%, #8a6526);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .footer__amp { font-style: italic; }
  .footer__motto { margin-top: 0.6rem; font-family: var(--font-display); font-style: italic; color: var(--steel-soft); max-width: 30rem; }
  .footer__heading {
    font-family: var(--font-display);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--gold-light);
    margin-bottom: 0.7rem;
  }
  .footer__links { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer__links a { color: var(--paper-deep); text-decoration: none; width: fit-content; }
  .footer__links a:hover { color: var(--gold-light); }
  .footer__base {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-block: 1.2rem;
    border-top: 1px solid rgba(184, 138, 60, 0.3);
    font-size: var(--step--1);
    color: var(--steel-soft);
  }
  @media (max-width: 640px) { .footer__grid { grid-template-columns: 1fr; } }
</style>
