---
import { withBase } from '../lib/utils';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'The Blog' },
  { href: '/the-record', label: 'The Record' },
  { href: '/about-me', label: 'About' },
  { href: '/faqs', label: 'FAQ' },
];
const norm = (p: string) => p.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const t = norm(withBase(href));
  return href === '/' ? path === norm(withBase('/')) : path === t || path.startsWith(t + '/');
};
---

<header class="mast">
  <div class="mast__top wrap">
    <!-- Fountain pen -->
    <svg class="mast__pen" viewBox="0 0 260 120" aria-hidden="true">
      <defs>
        <linearGradient id="goldGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#f0d695"/><stop offset="0.45" stop-color="#c79a45"/>
          <stop offset="0.55" stop-color="#a87f31"/><stop offset="1" stop-color="#e6c578"/>
        </linearGradient>
        <linearGradient id="steelGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#d7dde4"/><stop offset="0.5" stop-color="#8b95a3"/>
          <stop offset="1" stop-color="#5a6472"/>
        </linearGradient>
      </defs>
      <g transform="rotate(-9 130 60)">
        <rect x="14" y="40" width="120" height="34" rx="17" fill="url(#goldGrad)" stroke="#7c5d24"/>
        <path d="M30 42 q40 -10 80 0" fill="none" stroke="#f3e0a8" stroke-width="2" opacity="0.7"/>
        <rect x="128" y="38" width="9" height="38" rx="2" fill="#7c5d24"/>
        <polygon points="137,42 196,49 196,65 137,72" fill="url(#goldGrad)" stroke="#7c5d24"/>
        <polygon points="196,49 214,55 214,59 196,65" fill="#7c5d24"/>
        <polygon points="214,55 250,60 214,65 214,55" fill="url(#steelGrad)" stroke="#46505e" stroke-width="0.8"/>
        <line x1="216" y1="60" x2="246" y2="60" stroke="#46505e" stroke-width="0.8"/>
        <circle cx="220" cy="60" r="2" fill="#46505e"/>
      </g>
    </svg>

    <div class="mast__center">
      <a class="mast__word" href={withBase('/')} aria-label="The Ink &amp; Steel — home">
        THE INK <span class="mast__amp">&amp;</span> STEEL
      </a>
      <p class="mast__tag">Uncommon Sense for the Common Man · Sharper Than a Tack</p>
    </div>

    <!-- Steel I-beam -->
    <svg class="mast__beam" viewBox="0 0 200 150" aria-hidden="true">
      <defs>
        <linearGradient id="beamFront" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#c4ccd6"/><stop offset="0.5" stop-color="#838d9b"/>
          <stop offset="1" stop-color="#5a6472"/>
        </linearGradient>
        <linearGradient id="beamTop" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#e2e7ec"/><stop offset="1" stop-color="#aab2bd"/>
        </linearGradient>
      </defs>
      <g transform="rotate(8 100 75)">
        <!-- 3D depth -->
        <polygon points="30,28 58,12 150,12 122,28" fill="url(#beamTop)" stroke="#46505e" stroke-width="0.8"/>
        <polygon points="122,28 150,12 150,118 122,134" fill="#6c7684" stroke="#46505e" stroke-width="0.8"/>
        <!-- front I cross-section -->
        <path d="M22 28 H122 V52 H82 V110 H122 V134 H22 V110 H62 V52 H22 Z"
              fill="url(#beamFront)" stroke="#46505e" stroke-width="1"/>
        <line x1="26" y1="32" x2="118" y2="32" stroke="#dfe4ea" stroke-width="1.4" opacity="0.7"/>
        <circle cx="34" cy="40" r="3" fill="#46505e"/><circle cx="110" cy="40" r="3" fill="#46505e"/>
        <circle cx="34" cy="122" r="3" fill="#46505e"/><circle cx="110" cy="122" r="3" fill="#46505e"/>
      </g>
    </svg>
  </div>

  <nav class="mast__nav" aria-label="Primary">
    <button class="mast__toggle" aria-expanded="false" aria-controls="nav-links" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
    <div class="mast__links" id="nav-links">
      {
        links.map((l) => (
          <a
            href={withBase(l.href)}
            class:list={['mast__link', { 'is-active': isActive(l.href) }]}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<style>
  .mast {
    background-color: var(--navy);
    background-image: var(--leather-grain),
      radial-gradient(140% 120% at 50% 0%, var(--navy-soft), var(--navy) 60%, var(--navy-deep));
    border-bottom: 3px solid var(--gold-deep);
  }
  .mast__top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: clamp(0.5rem, 3vw, 2.5rem);
    padding-block: clamp(0.8rem, 2.5vw, 1.6rem);
  }
  .mast__pen { width: clamp(6rem, 14vw, 12rem); justify-self: end; filter: drop-shadow(0 3px 4px rgba(0,0,0,0.45)); }
  .mast__beam { width: clamp(5rem, 11vw, 9.5rem); justify-self: start; filter: drop-shadow(0 3px 4px rgba(0,0,0,0.45)); }

  .mast__center { text-align: center; }
  .mast__word {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 1rem + 5.5vw, 5.2rem);
    line-height: 1;
    letter-spacing: 0.01em;
    text-decoration: none;
    background: linear-gradient(180deg, #f6e6b4 0%, #d9b25c 38%, #a87f31 52%, #f0d695 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-stroke: 1px var(--gold-deep);
    filter: drop-shadow(0 2px 1px rgba(0,0,0,0.55));
    text-transform: uppercase;
  }
  .mast__amp { -webkit-text-stroke: 1px var(--gold-deep); font-style: italic; padding: 0 0.06em; }
  .mast__tag {
    margin-top: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(0.62rem, 0.5rem + 0.7vw, 0.95rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-light);
  }

  .mast__nav {
    background: var(--navy-deep);
    border-top: 1px solid var(--gold-deep);
    position: relative;
  }
  .mast__links {
    max-width: var(--wide);
    margin-inline: auto;
    padding: 0.55rem clamp(1.1rem, 4vw, 2.6rem);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.6rem, 2.5vw, 2rem);
  }
  .mast__link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-light);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.15s ease;
  }
  .mast__link::before { content: '['; color: var(--gold-deep); margin-right: 0.15em; }
  .mast__link::after { content: ']'; color: var(--gold-deep); margin-left: 0.15em; }
  .mast__link:hover { color: #fff; }
  .mast__link.is-active { color: #fff; }
  .mast__link.is-active::before, .mast__link.is-active::after { color: var(--gold-light); }

  .mast__toggle { display: none; flex-direction: column; gap: 5px; background: none; border: 0; padding: 0.6rem; cursor: pointer; margin-inline: auto; }
  .mast__toggle span { width: 26px; height: 2px; background: var(--gold-light); display: block; }

  @media (max-width: 760px) {
    .mast__pen, .mast__beam { display: none; }
    .mast__top { grid-template-columns: 1fr; }
    .mast__toggle { display: flex; }
    .mast__links { max-height: 0; overflow: hidden; flex-direction: column; align-items: center; padding-block: 0; transition: max-height 0.25s ease, padding-block 0.25s ease; }
    .mast__links.is-open { max-height: 60vh; padding-block: 0.6rem 1rem; }
    .mast__link { font-size: var(--step-0); }
  }
</style>

<script>
  const t = document.querySelector<HTMLButtonElement>('.mast__toggle');
  const l = document.querySelector<HTMLElement>('#nav-links');
  t?.addEventListener('click', () => {
    const open = l?.classList.toggle('is-open');
    t.setAttribute('aria-expanded', String(!!open));
  });
</script>
