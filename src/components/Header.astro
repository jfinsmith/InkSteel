---
import { withBase } from '../lib/utils';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'The Blog' },
  { href: '/the-record', label: 'The Record' },
  { href: '/about-me', label: 'About' },
  { href: '/fascism-watch', label: 'Fascism Watch' },
];
const norm = (p: string) => p.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const t = norm(withBase(href));
  return href === '/' ? path === norm(withBase('/')) : path === t || path.startsWith(t + '/');
};
---

<header class="mast">
  <div class="mast__top wrap">
    <a class="mast__home" href={withBase('/')} aria-label="The Ink &amp; Steel — home">
      <img
        class="mast__logo"
        src={withBase('/images/brand/logo-full.png')}
        alt="The Ink & Steel — Political Journal Focused on Common Sense"
        width="900"
        height="491"
        loading="eager"
        decoding="async"
      />
    </a>
  </div>

  <nav class="mast__nav" aria-label="Primary">
    <button class="mast__toggle" aria-expanded="false" aria-controls="nav-links" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
    <div class="mast__links" id="nav-links">
      {
        links.map((l) => (
          <a
            href={withBase(l.href)}
            class:list={['mast__link', { 'is-active': isActive(l.href) }]}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<style>
  /* Light parchment banner matching the logo's own background (#ede6d6) so the
     uncropped logo PNG sits seamlessly, no visible box. */
  .mast {
    background-color: #ede6d6;
    background-image: var(--paper-grain);
    border-bottom: 3px solid var(--gold-deep);
  }
  .mast__top {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding-block: clamp(0.5rem, 1.6vw, 1rem);
  }
  .mast__home { display: inline-block; line-height: 0; }
  .mast__logo {
    height: clamp(5rem, 7vw + 2rem, 10.5rem);
    width: auto;
    display: block;
  }

  /* --- Nav bar --- */
  .mast__nav {
    background: var(--navy-deep);
    border-top: 1px solid var(--gold-deep);
    position: relative;
  }
  .mast__links {
    max-width: var(--wide);
    margin-inline: auto;
    padding: 0.55rem clamp(1.1rem, 4vw, 2.6rem);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.6rem, 2.5vw, 2rem);
  }
  .mast__link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-light);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.15s ease;
  }
  .mast__link::before { content: '['; color: var(--gold-deep); margin-right: 0.15em; }
  .mast__link::after { content: ']'; color: var(--gold-deep); margin-left: 0.15em; }
  .mast__link:hover { color: #fff; }
  .mast__link.is-active { color: #fff; }
  .mast__link.is-active::before, .mast__link.is-active::after { color: var(--gold-light); }

  .mast__toggle { display: none; flex-direction: column; gap: 5px; background: none; border: 0; padding: 0.6rem; cursor: pointer; margin-inline: auto; }
  .mast__toggle span { width: 26px; height: 2px; background: var(--gold-light); display: block; }

  @media (max-width: 760px) {
    .mast__top { justify-content: center; }
    .mast__toggle { display: flex; }
    .mast__links { max-height: 0; overflow: hidden; flex-direction: column; align-items: center; padding-block: 0; transition: max-height 0.25s ease, padding-block 0.25s ease; }
    .mast__links.is-open { max-height: 60vh; padding-block: 0.6rem 1rem; }
    .mast__link { font-size: var(--step-0); }
  }
</style>

<script>
  const t = document.querySelector<HTMLButtonElement>('.mast__toggle');
  const l = document.querySelector<HTMLElement>('#nav-links');
  t?.addEventListener('click', () => {
    const open = l?.classList.toggle('is-open');
    t.setAttribute('aria-expanded', String(!!open));
  });
</script>
