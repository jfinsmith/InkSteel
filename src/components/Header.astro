---
import { withBase } from '../lib/utils';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'The Blog' },
  { href: '/the-record', label: 'The Record' },
  { href: '/about-me', label: 'About' },
  { href: '/fascism-watch', label: 'Fascism Watch' },
];
const norm = (p: string) => p.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const t = norm(withBase(href));
  return href === '/' ? path === norm(withBase('/')) : path === t || path.startsWith(t + '/');
};
---

<header class="mast">
  <div class="mast__top wrap">
    <a class="mast__lock" href={withBase('/')} aria-label="The Ink &amp; Steel — home">
      <img
        class="mast__logo"
        src={withBase('/images/brand/logo-journal.png')}
        alt="The Ink & Steel Journal — crossed fountain pen and dagger emblem"
        width="900"
        height="491"
        loading="eager"
        decoding="async"
      />
      <span class="mast__center">
        <span class="mast__word">THE INK <span class="mast__amp">&amp;</span> STEEL</span>
        <span class="mast__tag">Uncommon Sense for the Common Man</span>
      </span>
    </a>
  </div>

  <nav class="mast__nav" aria-label="Primary">
    <button class="mast__toggle" aria-expanded="false" aria-controls="nav-links" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
    <div class="mast__links" id="nav-links">
      {
        links.map((l) => (
          <a
            href={withBase(l.href)}
            class:list={['mast__link', { 'is-active': isActive(l.href) }]}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<style>
  .mast {
    background-color: var(--navy);
    background-image: var(--leather-grain),
      radial-gradient(140% 120% at 50% 0%, var(--navy-soft), var(--navy) 60%, var(--navy-deep));
    border-bottom: 3px solid var(--gold-deep);
  }

  /* Lockup: logo | gold hairline | wordmark + tagline */
  .mast__top { padding-block: clamp(0.6rem, 2vw, 1.2rem); }
  .mast__lock {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    text-decoration: none;
  }
  .mast__logo {
    grid-column: 1;
    justify-self: start;
    height: clamp(4rem, 5vw + 1.8rem, 7rem);
    width: auto;
    filter: drop-shadow(0 3px 5px rgba(0, 0, 0, 0.4));
  }

  .mast__center { grid-column: 2; display: flex; flex-direction: column; justify-content: center; text-align: center; align-items: center; }
  .mast__word {
    display: inline-block;
    max-width: 100%;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.4rem, 0.6rem + 4vw, 4.4rem);
    line-height: 1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    overflow-wrap: anywhere;
    background: linear-gradient(180deg, #f3eede 0%, #e6e0d0 34%, #c4ccd6 66%, #9aa6b4 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-stroke: 0.6px rgba(20, 28, 48, 0.35);
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.1), 0 2px 2px rgba(0, 0, 0, 0.55);
  }
  .mast__amp { font-style: italic; padding: 0 0.06em; -webkit-text-stroke: 0.6px rgba(20, 28, 48, 0.35); }
  .mast__tag {
    margin-top: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(0.62rem, 0.5rem + 0.7vw, 0.92rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #b9c2cd;
  }
  .mast__dot { color: var(--gold); padding: 0 0.15em; }

  /* --- Nav bar --- */
  .mast__nav {
    background: var(--navy-deep);
    border-top: 1px solid var(--gold-deep);
    position: relative;
  }
  .mast__links {
    max-width: var(--wide);
    margin-inline: auto;
    padding: 0.55rem clamp(1.1rem, 4vw, 2.6rem);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.6rem, 2.5vw, 2rem);
  }
  .mast__link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-light);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.15s ease;
  }
  .mast__link::before { content: '['; color: var(--gold-deep); margin-right: 0.15em; }
  .mast__link::after { content: ']'; color: var(--gold-deep); margin-left: 0.15em; }
  .mast__link:hover { color: #fff; }
  .mast__link.is-active { color: #fff; }
  .mast__link.is-active::before, .mast__link.is-active::after { color: var(--gold-light); }

  .mast__toggle { display: none; flex-direction: column; gap: 5px; background: none; border: 0; padding: 0.6rem; cursor: pointer; margin-inline: auto; }
  .mast__toggle span { width: 26px; height: 2px; background: var(--gold-light); display: block; }

  @media (max-width: 760px) {
    .mast__top { display: flex; justify-content: center; }
    .mast__lock { display: flex; flex-direction: column; align-items: center; gap: clamp(0.4rem, 2vw, 0.8rem); width: 100%; max-width: 100%; margin-inline: auto; }
    .mast__center { grid-column: auto; max-width: 100%; }
    .mast__toggle { display: flex; }
    .mast__links { max-height: 0; overflow: hidden; flex-direction: column; align-items: center; padding-block: 0; transition: max-height 0.25s ease, padding-block 0.25s ease; }
    .mast__links.is-open { max-height: 60vh; padding-block: 0.6rem 1rem; }
    .mast__link { font-size: var(--step-0); }
  }
</style>

<script>
  const t = document.querySelector<HTMLButtonElement>('.mast__toggle');
  const l = document.querySelector<HTMLElement>('#nav-links');
  t?.addEventListener('click', () => {
    const open = l?.classList.toggle('is-open');
    t.setAttribute('aria-expanded', String(!!open));
  });
</script>
