---
// Decorative "ink-wash plate" used as a thumbnail/hero when no raster image is
// supplied. Purely ornamental — the nib emblem on a seed-varied ink wash — so it
// never competes with or clips the real title shown alongside it.
interface Props {
  seed?: string;
  class?: string;
}
const { seed = 'ink', class: className = '' } = Astro.props;

// Cheap deterministic hash → stable visual variant from the slug/title.
function hash(s: string): number {
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return Math.abs(h);
}
const h = hash(seed);
const washColors = ['var(--oxblood)', 'var(--steel)', 'var(--ink)', 'var(--gold)'];
const wash = washColors[h % washColors.length];
const rot = (h % 24) - 12; // -12deg .. +11deg
const cx = 20 + (h % 55); // blob horizontal anchor %
const cy = 14 + (h % 38);
---

<div
  class:list={['hero-plate', className]}
  style={`--wash:${wash}; --rot:${rot}deg; --cx:${cx}%; --cy:${cy}%`}
  role="presentation"
>
  <svg class="hero-plate__wash" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <path
      d="M40 60 C70 30 130 28 150 64 C168 96 158 120 130 138 C104 154 70 158 48 134 C26 110 18 92 28 76 Z"
      fill="var(--wash)" opacity="0.16"></path>
    <path
      d="M70 40 C110 28 150 52 152 92 C154 128 120 150 86 146 C54 142 40 116 44 88 C47 64 50 46 70 40 Z"
      fill="var(--wash)" opacity="0.10"></path>
  </svg>
  <svg class="hero-plate__nib" viewBox="0 0 100 150" aria-hidden="true">
    <path fill="currentColor" d="M50 8 C72 8 88 22 88 42 L55 124 C53 130 47 130 45 124 L12 42 C12 22 28 8 50 8 Z"></path>
    <circle cx="50" cy="48" r="8.5" fill="var(--paper-deep)"></circle>
    <path d="M50 56 L50 120" stroke="var(--paper-deep)" stroke-width="3" stroke-linecap="round"></path>
  </svg>
</div>

<style>
  .hero-plate {
    position: relative;
    overflow: hidden;
    background: var(--paper-deep);
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius);
    aspect-ratio: 16 / 9;
    display: grid;
    place-items: center;
    isolation: isolate;
  }
  .hero-plate__wash {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    z-index: 0;
    transform: translate(calc(var(--cx) - 40%), calc(var(--cy) - 30%)) rotate(var(--rot)) scale(1.3);
  }
  .hero-plate__nib {
    position: relative;
    z-index: 1;
    width: auto;
    height: clamp(2rem, 4vw, 3rem);
    color: var(--ink);
    opacity: 0.7;
  }
</style>
