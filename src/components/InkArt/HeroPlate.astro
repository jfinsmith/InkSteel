---
// Generated "ink-wash plate" used as a post hero when no raster image is supplied,
// and on taxonomy/listing pages. Deterministic per `seed` so each looks distinct.
interface Props {
  title: string;
  kicker?: string;
  seed?: string;
  class?: string;
}
const { title, kicker = 'Dispatch', seed = title, class: className = '' } = Astro.props;

// Cheap deterministic hash → stable visual variant from the slug/title.
function hash(s: string): number {
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return Math.abs(h);
}
const h = hash(seed);
const washColors = ['var(--oxblood)', 'var(--steel)', 'var(--ink)', 'var(--gold)'];
const wash = washColors[h % washColors.length];
const rot = (h % 24) - 12; // -12deg .. +11deg
const cx = 18 + (h % 60); // blob horizontal anchor %
const cy = 12 + (h % 40);
---

<div class:list={['hero-plate', className]} style={`--wash:${wash}; --rot:${rot}deg; --cx:${cx}%; --cy:${cy}%`}>
  <svg class="hero-plate__wash" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <path
      d="M40 60 C70 30 130 28 150 64 C168 96 158 120 130 138 C104 154 70 158 48 134 C26 110 18 92 28 76 Z"
      fill="var(--wash)" opacity="0.16"></path>
    <path
      d="M70 40 C110 28 150 52 152 92 C154 128 120 150 86 146 C54 142 40 116 44 88 C47 64 50 46 70 40 Z"
      fill="var(--wash)" opacity="0.10"></path>
  </svg>
  <div class="hero-plate__body">
    <svg class="hero-plate__nib" viewBox="0 0 100 150" aria-hidden="true">
      <path fill="currentColor" d="M50 8 C72 8 88 22 88 42 L55 124 C53 130 47 130 45 124 L12 42 C12 22 28 8 50 8 Z"></path>
      <circle cx="50" cy="48" r="8.5" fill="var(--paper)"></circle>
      <path d="M50 56 L50 120" stroke="var(--paper)" stroke-width="3" stroke-linecap="round"></path>
    </svg>
    {kicker && <p class="hero-plate__kicker">{kicker}</p>}
    <p class="hero-plate__title">{title}</p>
  </div>
</div>

<style>
  .hero-plate {
    position: relative;
    overflow: hidden;
    background: var(--paper-deep);
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius);
    aspect-ratio: 16 / 9;
    display: grid;
    place-items: center;
    isolation: isolate;
  }
  .hero-plate__wash {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    z-index: 0;
    transform: translate(calc(var(--cx) - 40%), calc(var(--cy) - 30%)) rotate(var(--rot)) scale(1.3);
  }
  .hero-plate__body {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem clamp(1.2rem, 5vw, 3rem);
    max-width: 46rem;
  }
  .hero-plate__nib {
    width: auto;
    height: 2.2rem;
    margin: 0 auto 1rem;
    color: var(--ink);
    opacity: 0.85;
  }
  .hero-plate__kicker {
    font-family: var(--font-display);
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--oxblood);
    margin-bottom: 0.6rem;
  }
  .hero-plate__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-3);
    line-height: 1.08;
    color: var(--ink);
    text-wrap: balance;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    max-width: none;
  }
</style>
