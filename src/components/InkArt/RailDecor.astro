---
// Decorative right-hand rail for long-form pages — a faint vertical flourish
// (nib + rule + vertical wordmark) that fills the wide-screen third column.
interface Props { color?: string }
const { color = 'var(--steel)' } = Astro.props;
---
<aside class="longform__aside rail-decor" aria-hidden="true" style={`--decor:${color}`}>
  <svg class="rail-decor__splatter" viewBox="0 0 200 200">
    <g fill="var(--decor)">
      <path d="M96 40 C120 38 134 58 128 82 C122 104 138 118 120 134 C104 148 78 142 66 122 C54 102 60 86 70 72 C78 60 80 42 96 40 Z" opacity="0.9"></path>
      <circle cx="150" cy="64" r="7" opacity="0.8"></circle>
      <circle cx="44" cy="150" r="5" opacity="0.7"></circle>
      <circle cx="160" cy="120" r="3.4" opacity="0.6"></circle>
    </g>
  </svg>
  <span class="rail-decor__rule"></span>
  <svg class="rail-decor__nib" viewBox="0 0 100 150">
    <path fill="currentColor" d="M50 8 C72 8 88 22 88 42 L55 124 C53 130 47 130 45 124 L12 42 C12 22 28 8 50 8 Z"></path>
    <circle cx="50" cy="48" r="8.5" fill="var(--paper)"></circle>
    <path d="M50 56 L50 120" stroke="var(--paper)" stroke-width="3" stroke-linecap="round"></path>
  </svg>
  <span class="rail-decor__word">The Ink &amp; Steel</span>
</aside>

<style>
  .rail-decor {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;
    color: var(--ink);
    padding-left: 1rem;
  }
  .rail-decor__splatter { width: 7rem; height: 7rem; opacity: 0.12; }
  .rail-decor__rule { width: 1px; height: 5rem; background: var(--paper-edge); }
  .rail-decor__nib { height: 2.6rem; width: auto; opacity: 0.35; }
  .rail-decor__word {
    writing-mode: vertical-rl;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    font-size: var(--step--1);
    color: var(--ink-faint);
    opacity: 0.7;
  }
</style>
