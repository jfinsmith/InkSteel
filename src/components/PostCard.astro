---
import type { CollectionEntry } from 'astro:content';
import HeroPlate from './InkArt/HeroPlate.astro';
import { withBase } from '../lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const { title, excerpt, pubDate, categories, tags, heroImage, heroImageAlt } = post.data;
const slug = post.id;
const primary = categories[0];
const isRaster = heroImage && /\.(png|jpe?g|webp|gif|avif)$/i.test(heroImage);
const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(d);
---

<article class:list={['card', { 'card--featured': featured }]}>
  <a href={withBase(`/blog/${slug}`)} class="card__media" aria-hidden="true" tabindex="-1">
    {isRaster ? (
      <img src={withBase(heroImage!)} alt={heroImageAlt ?? ''} loading="lazy" width="800" height="450" />
    ) : (
      <HeroPlate seed={slug} />
    )}
  </a>
  <div class="card__body">
    {primary && <span class="kicker">{primary}</span>}
    <h3 class="card__title">
      <a href={withBase(`/blog/${slug}`)}>{title}</a>
    </h3>
    <p class="card__excerpt">{excerpt}</p>
    <div class="card__meta meta">
      <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
      {tags[0] && <span> · #{tags[0]}</span>}
    </div>
  </div>
</article>

<style>
  /* Newspaper clipping / plaque */
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--paper-deep);
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .card__media { display: block; overflow: hidden; border-bottom: 1px solid var(--paper-edge); }
  .card__media img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; filter: grayscale(0.18) sepia(0.16) contrast(1.05) brightness(0.99); transition: transform 0.4s ease; }
  .card__media:hover img { transform: scale(1.03); }
  .card__body { padding: 0.85rem 1.05rem 1.05rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .card__title { font-size: var(--step-1); line-height: 1.1; margin-top: 0.15rem; }
  .card__title a { color: var(--ink); text-decoration: none; transition: color 0.2s ease; }
  .card__title a:hover { color: var(--oxblood); }
  .card__excerpt { color: var(--ink-soft); font-size: var(--step--1); max-width: none; }

  /* Featured card: media beside text on wide screens */
  .card--featured { display: grid; grid-template-columns: 1fr 1.05fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .card--featured .card__title { font-size: var(--step-2); }
  .card--featured .card__excerpt { font-size: var(--step-1); font-family: var(--font-display); font-style: italic; color: var(--ink-soft); }
  @media (max-width: 760px) {
    .card--featured { grid-template-columns: 1fr; }
  }
</style>
