---
import type { CollectionEntry } from 'astro:content';
import HeroPlate from './InkArt/HeroPlate.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const { title, excerpt, pubDate, categories, tags, heroImage, heroImageAlt } = post.data;
const slug = post.id;
const primary = categories[0];
const isRaster = heroImage && /\.(png|jpe?g|webp|gif|avif)$/i.test(heroImage);
const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(d);
---

<article class:list={['card', { 'card--featured': featured }]}>
  <a href={`/blog/${slug}`} class="card__media" aria-hidden="true" tabindex="-1">
    {isRaster ? (
      <img src={heroImage} alt={heroImageAlt ?? ''} loading="lazy" width="800" height="450" />
    ) : (
      <HeroPlate title={title} kicker={primary ?? 'Dispatch'} seed={slug} />
    )}
  </a>
  <div class="card__body">
    {primary && <span class="kicker">{primary}</span>}
    <h3 class="card__title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>
    <p class="card__excerpt">{excerpt}</p>
    <div class="card__meta meta">
      <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
      {tags[0] && <span> · #{tags[0]}</span>}
    </div>
  </div>
</article>

<style>
  .card { display: flex; flex-direction: column; height: 100%; }
  .card__media { display: block; border-radius: var(--radius); overflow: hidden; }
  .card__media img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; transition: transform 0.4s ease; }
  .card__media:hover img { transform: scale(1.03); }
  .card__body { padding-top: 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .card__title { font-size: var(--step-1); line-height: 1.12; margin-top: 0.2rem; }
  .card__title a { color: var(--ink); text-decoration: none; background-image: linear-gradient(var(--oxblood), var(--oxblood)); background-size: 0% 2px; background-position: 0 100%; background-repeat: no-repeat; transition: background-size 0.3s ease, color 0.2s ease; }
  .card__title a:hover { color: var(--oxblood); background-size: 100% 2px; }
  .card__excerpt { color: var(--ink-soft); font-size: var(--step-0); max-width: none; }

  /* Featured card: media beside text on wide screens */
  .card--featured { display: grid; grid-template-columns: 1.15fr 1fr; gap: clamp(1.2rem, 3vw, 2.5rem); align-items: center; }
  .card--featured .card__title { font-size: var(--step-3); }
  .card--featured .card__excerpt { font-size: var(--step-1); font-family: var(--font-display); font-style: italic; color: var(--ink-soft); }
  @media (max-width: 760px) {
    .card--featured { grid-template-columns: 1fr; }
  }
</style>
