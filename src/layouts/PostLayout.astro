---
import BaseLayout from './BaseLayout.astro';
import HeroPlate from '../components/InkArt/HeroPlate.astro';
import Divider from '../components/InkArt/Divider.astro';
import Newsletter from '../components/Newsletter.astro';
import ViewCounter from '../components/ViewCounter.astro';
import { slugify, withBase, formatDate } from '../lib/utils';

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  excerpt: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  categories: string[];
  heroImage?: string;
  heroImageAlt?: string;
  canonicalURL?: string;
  slug: string;
  readingTime: number;
}
const {
  title, seoTitle, description, excerpt, pubDate, updatedDate, author,
  tags, categories, heroImage, heroImageAlt, canonicalURL, slug, readingTime,
} = Astro.props;

const primaryCategory = categories[0];
const isRasterHero = heroImage && /\.(png|jpe?g|webp|gif|avif)$/i.test(heroImage);
---

<BaseLayout
  title={seoTitle ?? `${title} · The Ink & Steel`}
  description={description}
  image={isRasterHero ? heroImage : undefined}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  author={author}
  tags={tags}
  section={primaryCategory}
  canonicalURL={canonicalURL}
>
  <article class="bp wrap">
    <!-- Front-of-article: hero image on the left, masthead (kicker/title/deck/
         byline) beside it. Spans the full sheet so nothing is smooshed. -->
    <header class="bp__head">
      <div class="bp__media">
        {isRasterHero ? (
          <img src={withBase(heroImage!)} alt={heroImageAlt ?? title} width="900" height="675" loading="eager" decoding="async" />
        ) : (
          <HeroPlate seed={slug} />
        )}
        {heroImageAlt && isRasterHero && <p class="bp__caption">{heroImageAlt}</p>}
      </div>

      <div class="bp__intro">
        {primaryCategory && (
          <a href={withBase(`/categories/${slugify(primaryCategory)}`)} class="kicker">{primaryCategory}</a>
        )}
        <h1 class="bp__title">{title}</h1>
        <p class="bp__deck">{excerpt}</p>
        <div class="bp__byline">
          <span>By <strong>{author}</strong></span>
          <span class="bp__sep" aria-hidden="true">·</span>
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          <span class="bp__sep" aria-hidden="true">·</span>
          <span>{readingTime} min read</span>
          <span class="bp__sep bp__sep--views" aria-hidden="true">·</span>
          <ViewCounter slug={slug} />
        </div>
        {updatedDate && <p class="bp__updated">Updated {formatDate(updatedDate)}</p>}
      </div>
    </header>

    <!-- Broadsheet body: text flows across the full width in newspaper columns -->
    <div class="bp__body prose dropcap">
      <slot />
    </div>

    <Divider class="bp__rule" />

    <footer class="bp__foot">
      {tags.length > 0 && (
        <div class="bp__tags">
          {tags.map((t) => <a class="chip" href={withBase(`/tags/${slugify(t)}`)}>#{t}</a>)}
        </div>
      )}
      <div class="bp__news"><Newsletter /></div>
      <p class="bp__back"><a href={withBase('/blog')}>← Back to all dispatches</a></p>
    </footer>
  </article>
</BaseLayout>

<style>
  .bp { padding-block: clamp(1.4rem, 3.5vw, 2.4rem) clamp(2.5rem, 6vw, 4rem); }

  /* --- Masthead: image left, title block beside it ---------------------- */
  .bp__head {
    display: grid;
    gap: clamp(1.2rem, 3vw, 2.4rem);
    align-items: start;
    padding-bottom: 1.4rem;
    margin-bottom: 1.8rem;
    border-bottom: 4px double var(--ink);
  }
  @media (min-width: 52rem) {
    .bp__head { grid-template-columns: minmax(0, 40%) 1fr; }
  }
  .bp__media img,
  .bp__media :global(.hero-plate) {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    filter: grayscale(0.16) sepia(0.14) contrast(1.04) brightness(0.99);
  }
  .bp__caption { margin-top: 0.5rem; font-size: var(--step--1); font-style: italic; color: var(--ink-faint); }

  .bp__title { font-size: var(--step-4); line-height: 1.02; margin: 0.5rem 0 0.6rem; }
  .bp__deck {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.26;
    color: var(--ink-soft);
    max-width: none;
  }
  .bp__byline { margin-top: 1rem; display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.45rem; font-size: var(--step--1); color: var(--ink-faint); }
  .bp__byline strong { color: var(--ink); }
  .bp__byline time { color: var(--ink-faint); }
  .bp__sep { color: var(--paper-edge); }
  .bp__sep--views { display: none; }
  .bp__byline:has(.views:not([hidden])) .bp__sep--views { display: inline; }
  .bp__byline :global(.views) { color: var(--ink-faint); }
  .bp__updated { margin-top: 0.35rem; font-style: italic; font-size: var(--step--1); color: var(--ink-faint); }

  /* --- Body: one comfortable column, larger type ---------------------- */
  .bp__body {
    max-width: 64rem;
    margin-inline: auto;
    font-size: clamp(1.18rem, 1.08rem + 0.45vw, 1.34rem);
    line-height: 1.72;
  }
  .bp__body :global(:where(p, ul, ol, blockquote, h2, h3, h4, figure, img)) { max-width: none; }
  .bp__body :global(h2) { margin-top: 1.5em; }
  .bp__body :global(h2:first-child), .bp__body :global(p:first-child) { margin-top: 0; }

  /* --- Footer ---------------------------------------------------------- */
  .bp :global(.bp__rule) { margin-block: clamp(2rem, 4vw, 2.8rem); }
  .bp__foot { margin-top: 0.5rem; }
  .bp__tags { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-bottom: 1.8rem; }
  .bp__news { max-width: 48rem; margin-bottom: 1.8rem; }
  .bp__back a { font-family: var(--font-display); font-weight: 700; text-decoration: none; color: var(--ink-soft); }
  .bp__back a:hover { color: var(--oxblood); }
</style>
