---
import BaseLayout from './BaseLayout.astro';
import HeroPlate from '../components/InkArt/HeroPlate.astro';
import Divider from '../components/InkArt/Divider.astro';
import Newsletter from '../components/Newsletter.astro';
import ViewCounter from '../components/ViewCounter.astro';
import { slugify, withBase } from '../lib/utils';

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  excerpt: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  categories: string[];
  heroImage?: string;
  heroImageAlt?: string;
  canonicalURL?: string;
  slug: string;
  readingTime: number;
}
const {
  title, seoTitle, description, excerpt, pubDate, updatedDate, author,
  tags, categories, heroImage, heroImageAlt, canonicalURL, slug, readingTime,
} = Astro.props;

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);
const primaryCategory = categories[0];
const isRasterHero = heroImage && /\.(png|jpe?g|webp|gif|avif)$/i.test(heroImage);
---

<BaseLayout
  title={seoTitle ?? `${title} · The Ink & Steel`}
  description={description}
  image={isRasterHero ? heroImage : undefined}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  author={author}
  tags={tags}
  section={primaryCategory}
  canonicalURL={canonicalURL}
>
  <article class="post">
    <header class="post__header wrap">
      {primaryCategory && (
        <a href={withBase(`/categories/${slugify(primaryCategory)}`)} class="kicker post__kicker">
          {primaryCategory}
        </a>
      )}
      <h1 class="post__title">{title}</h1>
      <p class="post__deck">{excerpt}</p>
    </header>

    <figure class="post__hero wrap">
      {isRasterHero ? (
        <img src={heroImage} alt={heroImageAlt ?? title} width="1200" height="675" loading="eager" />
      ) : (
        <HeroPlate seed={slug} class="post__hero-plate" />
      )}
    </figure>

    <div class="wrap longform">
      <aside class="longform__rail">
        <div class="longform__meta post__meta">
          <p>By <strong>{author}</strong></p>
          <p><time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time></p>
          <p>{readingTime} min read · <ViewCounter slug={slug} /></p>
          {updatedDate && <p class="post__updated">Updated {fmt(updatedDate)}</p>}
        </div>
        {tags.length > 0 && (
          <div class="post__tags">
            {tags.map((t) => (
              <a class="chip" href={withBase(`/tags/${slugify(t)}`)}>#{t}</a>
            ))}
          </div>
        )}
        <p class="post__back"><a href={withBase('/blog')}>← All dispatches</a></p>
      </aside>

      <div class="longform__main prose dropcap">
        <slot />
        <Divider />
        <Newsletter />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post__header { max-width: 60rem; padding-top: clamp(2.5rem, 6vw, 4rem); }
  .post__kicker { text-decoration: none; display: inline-block; margin-bottom: 1rem; }
  .post__title { font-size: var(--step-4); margin-bottom: 0.8rem; }
  .post__deck {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--ink-soft);
    max-width: 44rem;
  }

  .post__hero { max-width: var(--wide); margin: 2.5rem auto 0; }
  .post__hero img { width: 100%; border-radius: var(--radius); box-shadow: var(--shadow); object-fit: cover; }
  /* Decorative plate as a calm banner, not a tall empty box. */
  .post__hero :global(.post__hero-plate) { aspect-ratio: auto; height: clamp(10rem, 22vw, 17rem); }

  .post__meta strong { color: var(--ink); }
  .post__meta time { color: var(--ink-soft); }
  .post__updated { font-style: italic; }
  .post__tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 1.4rem; }
  .post__back { margin-top: 1.4rem; }
  .post__back a { font-family: var(--font-display); text-decoration: none; }
  .post__back a:hover { color: var(--oxblood); }
</style>
