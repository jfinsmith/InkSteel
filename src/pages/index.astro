---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Divider from '../components/InkArt/Divider.astro';
import Splatter from '../components/InkArt/Splatter.astro';
import Newsletter from '../components/Newsletter.astro';
import { withBase } from '../lib/utils';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;
const recent = rest.slice(0, 6);
---

<BaseLayout
  title="The Ink & Steel — Bringing Common Sense to the People"
  description="From the Desk of Sanity: sharp, sourced political commentary decoding the second Trump term. The pen is mightier than the sword."
>
  <!-- Manifesto hero -->
  <section class="hero">
    <div class="hero__splatter" aria-hidden="true"><Splatter color="var(--oxblood)" /></div>
    <div class="wrap hero__inner">
      <p class="kicker">The pen is mightier than the sword</p>
      <h1 class="hero__headline">
        Bringing <em>common sense</em> back to the people.
      </h1>
      <p class="hero__lede">
        A personal news outlet for the politically exhausted — documenting the second
        Trump term with wit, evidence, and an unreasonable fondness for the truth.
      </p>
      <div class="hero__actions">
        <a href={withBase('/blog')} class="btn">Read the latest</a>
        <a href={withBase('/about-me')} class="btn btn--ghost">Why this exists</a>
      </div>
    </div>
  </section>

  <Divider />

  {
    featured && (
      <section class="wrap section">
        <h2 class="section__label"><span>Latest Dispatch</span></h2>
        <PostCard post={featured} featured />
      </section>
    )
  }

  {
    recent.length > 0 && (
      <section class="wrap section">
        <h2 class="section__label"><span>More from the desk</span></h2>
        <div class="grid">
          {recent.map((post) => <PostCard post={post} />)}
        </div>
        <p class="section__more">
          <a href={withBase('/blog')} class="btn btn--ghost">Browse all dispatches →</a>
        </p>
      </section>
    )
  }

  <!-- Mission band -->
  <section class="creed">
    <div class="wrap creed__inner">
      <p class="creed__quote">
        “Criticism stems from decency, truth, and the rule of law — not partisanship.
        We document the absurd so we don't have to accept it.”
      </p>
      <p class="creed__by">— The Ink &amp; Steel</p>
    </div>
  </section>

  <section class="wrap section section--cta">
    <Newsletter />
  </section>
</BaseLayout>

<style>
  .hero { position: relative; overflow: hidden; padding-block: clamp(3rem, 9vw, 6.5rem); }
  .hero__splatter {
    position: absolute; top: -4rem; right: -3rem; width: 28rem; height: 28rem;
    opacity: 0.08; z-index: 0; pointer-events: none;
  }
  .hero__inner { position: relative; z-index: 1; max-width: 62rem; }
  .hero__headline {
    font-size: var(--step-5);
    margin: 0.6rem 0 1.2rem;
    letter-spacing: -0.02em;
  }
  .hero__headline em { color: var(--oxblood); font-style: italic; }
  .hero__lede {
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--ink-soft);
    max-width: 46rem;
    line-height: 1.45;
  }
  .hero__actions { display: flex; gap: 0.8rem; margin-top: 2rem; flex-wrap: wrap; }

  .section { padding-block: clamp(2rem, 5vw, 3.5rem); }
  .section__label {
    display: flex; align-items: center; gap: 1rem;
    font-size: var(--step-0); text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--oxblood); font-weight: 600; margin-bottom: 2rem;
  }
  .section__label::after { content: ''; flex: 1; height: 1px; background: var(--paper-edge); }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 19rem), 1fr));
    gap: clamp(1.6rem, 4vw, 2.8rem);
  }
  .section__more { margin-top: 2.5rem; text-align: center; }

  .creed {
    margin-top: 3rem;
    background: var(--ink);
    background-image: var(--paper-grain);
    color: var(--paper);
    padding-block: clamp(3rem, 8vw, 5rem);
  }
  .creed__inner { max-width: 46rem; text-align: center; }
  .creed__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.3;
    max-width: none;
    text-wrap: balance;
  }
  .creed__by { margin-top: 1.5rem; color: var(--steel-soft); letter-spacing: 0.06em; }
  .section--cta { max-width: 48rem; margin-inline: auto; }
</style>
